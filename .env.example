# Vibe Calculators — environment variables
#
# Copy this file to `.env` and fill in real values for your deploy.
# `apps/api` validates required values via Zod at boot (src/lib/env.ts);
# missing or malformed values cause a clear startup error and exit 78.

# ----------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------

# One of: development | test | production
NODE_ENV=production

# Port the API listens on inside the container. The Caddy ingress
# proxies /api/* to api:3000, so changing this requires updating
# docker-compose.yml's healthcheck and the ingress reverse_proxy line.
PORT=3000

# pino log level: fatal|error|warn|info|debug|trace|silent
LOG_LEVEL=info

# ----------------------------------------------------------------------
# Data plane
# ----------------------------------------------------------------------

# Postgres connection. The compose file builds this from POSTGRES_USER /
# POSTGRES_PASSWORD / POSTGRES_DB; for non-compose deploys set DATABASE_URL
# directly. Database name and user follow the Vibe family convention
# (Vibe-Appliance/console/manifests/*.json).
# REQUIRED — generate strong values and keep them out of source control.
# `openssl rand -base64 32` produces a fine 256-bit password.
POSTGRES_USER=vibecalculators
POSTGRES_PASSWORD=
POSTGRES_DB=vibe_calculators_db
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Redis (BullMQ + cache). DB slot 2 is allocated to vibe-calculators in
# the Vibe family (slots 0 tb, 1 mybooks, 2 calculators, 3 tax-research,
# 4 payroll, 5 glm-ocr).
# REQUIRED — `openssl rand -base64 32`
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/2
VIBE_REDIS_DB=2

# ----------------------------------------------------------------------
# Deploy mode (Phase 1.11 Caddyfile dispatcher)
# ----------------------------------------------------------------------

# One of: lan | domain | tailscale
#   lan       — HTTP on :80 inside the firm network
#   domain    — Auto-HTTPS via ACME for VIBE_DOMAIN
#   tailscale — Plaintext :8000 behind `tailscale serve`
VIBE_DEPLOY_MODE=lan

# Required when VIBE_DEPLOY_MODE=domain
VIBE_DOMAIN=
VIBE_TLS_EMAIL=

# ----------------------------------------------------------------------
# Host port mapping (compose-side)
# ----------------------------------------------------------------------

# Override only if 80/443 collide with another service on the host.
VIBE_HTTP_PORT=80
VIBE_HTTPS_PORT=443

# Tailscale-mode listener inside the container; consumed by
# compose.tailscale.override.yml.
VIBE_TS_PORT=8000

# ----------------------------------------------------------------------
# Appliance options
# ----------------------------------------------------------------------

# When true, disables outbound IRS-AFR fetch, telemetry, image-update
# checks. Phase 22 / 23 / 25 read this.
VIBE_OFFLINE=false

# AES-256-GCM key (32 bytes, base64) used by Phase 23 to encrypt the
# per-firm Anthropic API key at rest. Generate with:
#   openssl rand -base64 32
# Required only when AI features are enabled; safe to leave blank
# until Phase 23 is wired up.
VIBE_KMS_KEY=

# ----------------------------------------------------------------------
# Email delivery (Phase 22)
# ----------------------------------------------------------------------

# One of: smtp | postmark | emailit
VIBE_EMAIL_PROVIDER=smtp

# SMTP (relay path — Postmark/SendGrid/Mailgun/SES via SMTP all work here)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=noreply@firm.test

# Postmark
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM=noreply@firm.test
POSTMARK_STREAM=outbound

# EmailIt
EMAILIT_API_KEY=
EMAILIT_FROM=noreply@firm.test
EMAILIT_ENDPOINT=

# ----------------------------------------------------------------------
# AI extraction (Phase 23)
# ----------------------------------------------------------------------

# Provider selection (optional). One of: anthropic | local. When
# omitted, the appliance picks Anthropic if ANTHROPIC_API_KEY is set,
# otherwise Local if VIBE_LLM_LOCAL_URL is set. With VIBE_OFFLINE=true
# only the local provider is selectable regardless.
VIBE_LLM_PROVIDER=

# Claude API key for loan-agreement extraction. Leave blank to disable.
ANTHROPIC_API_KEY=

# Override the default Claude model. Default: claude-sonnet-4-6.
VIBE_LLM_DEFAULT_MODEL=

# Local OpenAI-wire-format LLM gateway (vibe-llm-server, llama.cpp,
# Ollama, etc.). The base URL must include the /v1 prefix. Example:
#   VIBE_LLM_LOCAL_URL=http://vibe-llm:8080/v1
VIBE_LLM_LOCAL_URL=
VIBE_LLM_LOCAL_MODEL=
VIBE_LLM_LOCAL_API_KEY=

# Token-cost rate sheet (USD per 1M tokens). Default reflects Claude
# Sonnet 4.6 list price. Override per the rate sheet you actually pay.
VIBE_LLM_PRICE_INPUT_PER_M=
VIBE_LLM_PRICE_OUTPUT_PER_M=

# ----------------------------------------------------------------------
# Tax tables (Phase 22.2)
# ----------------------------------------------------------------------

# IRS Applicable Federal Rate feed URL. Production firms point this
# at their preferred mirror (the IRS does not publish JSON natively).
VIBE_AFR_FEED_URL=

# ----------------------------------------------------------------------
# Build / image metadata (set by CI; ignore for local dev)
# ----------------------------------------------------------------------

# Short SHA injected at image build time; reported by /api/health.
GIT_SHA=

# Image tag pulled by docker compose (e.g. 'latest' or '0.1.0').
VIBE_IMAGE_TAG=dev

# Application version baked into OCI labels.
VIBE_VERSION=0.0.0-dev
