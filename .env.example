# Vibe Calculators — environment variables
#
# Copy this file to `.env` and fill in real values for your deploy.
# `apps/api` validates required values via Zod at boot (src/lib/env.ts);
# missing or malformed values cause a clear startup error and exit 78.

# ----------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------

# One of: development | test | production
NODE_ENV=production

# Port the API listens on inside the container. The Caddy ingress
# proxies /api/* to api:3000, so changing this requires updating
# docker-compose.yml's healthcheck and the ingress reverse_proxy line.
PORT=3000

# pino log level: fatal|error|warn|info|debug|trace|silent
LOG_LEVEL=info

# ----------------------------------------------------------------------
# Data plane
# ----------------------------------------------------------------------

# Postgres connection. The compose file builds this from POSTGRES_USER /
# POSTGRES_PASSWORD / POSTGRES_DB; for non-compose deploys set DATABASE_URL
# directly.
DATABASE_URL=postgres://vibe:vibe@postgres:5432/vibecalc
POSTGRES_USER=vibe
POSTGRES_PASSWORD=vibe
POSTGRES_DB=vibecalc

# Redis (BullMQ + cache).
REDIS_URL=redis://redis:6379

# ----------------------------------------------------------------------
# Deploy mode (Phase 1.11 Caddyfile dispatcher)
# ----------------------------------------------------------------------

# One of: lan | domain | tailscale
#   lan       — HTTP on :80 inside the firm network
#   domain    — Auto-HTTPS via ACME for VIBE_DOMAIN
#   tailscale — Plaintext :8000 behind `tailscale serve`
VIBE_DEPLOY_MODE=lan

# Required when VIBE_DEPLOY_MODE=domain
VIBE_DOMAIN=
VIBE_TLS_EMAIL=

# ----------------------------------------------------------------------
# Host port mapping (compose-side)
# ----------------------------------------------------------------------

# Override only if 80/443 collide with another service on the host.
VIBE_HTTP_PORT=80
VIBE_HTTPS_PORT=443

# Tailscale-mode listener inside the container; consumed by
# compose.tailscale.override.yml.
VIBE_TS_PORT=8000

# ----------------------------------------------------------------------
# Appliance options
# ----------------------------------------------------------------------

# When true, disables outbound IRS-AFR fetch, telemetry, image-update
# checks. Phase 22 / 23 / 25 read this.
VIBE_OFFLINE=false

# AES-256-GCM key (32 bytes, base64) used by Phase 23 to encrypt the
# per-firm Anthropic API key at rest. Generate with:
#   openssl rand -base64 32
# Required only when AI features are enabled; safe to leave blank
# until Phase 23 is wired up.
VIBE_KMS_KEY=

# ----------------------------------------------------------------------
# Build / image metadata (set by CI; ignore for local dev)
# ----------------------------------------------------------------------

# Short SHA injected at image build time; reported by /api/health.
GIT_SHA=

# Image tag pulled by docker compose (e.g. 'latest' or '0.1.0').
VIBE_IMAGE_TAG=dev

# Application version baked into OCI labels.
VIBE_VERSION=0.0.0-dev
