    "pino": "9.5.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/express": "5.0.0",
    "@types/pg": "8.11.10",
    "@types/supertest": "6.0.2",
    "pino-pretty": "13.0.0",
    "supertest": "7.0.0",
    "tsx": "4.19.2",
    "vitest": "2.1.4"
