{
  "name": "@vibe-calc/db",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "seed-tax-tables": "tsx src/seed-tax-tables.ts",
    "bootstrap": "tsx src/bootstrap-cli.ts"
  },
  "dependencies": {
    "drizzle-orm": "0.36.4",
    "pg": "8.13.1"
  },
  "devDependencies": {
    "@types/pg": "8.11.10",
    "drizzle-kit": "0.28.1",
    "tsx": "4.19.2",
    "vitest": "2.1.4"
  }
}
